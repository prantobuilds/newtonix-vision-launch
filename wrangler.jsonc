{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "newtonix",
  "compatibility_date": "2026-06-25",
  "compatibility_flags": ["nodejs_compat"],
  "main": "dist/server/server.js",
  "assets": {
    "directory": "dist/client",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  }
}
